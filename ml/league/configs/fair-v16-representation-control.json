  "sample": true,
  "temperature": 0.65,
  "train": {
    "epochs": 2,
    "batchSize": 256,
    "hidden": [128, 128],
    "valueHidden": [64],
    "extraArgs": [
      "--lr", "0.0001",
      "--clip-eps", "0.1",
      "--entropy-coef", "0.002",
      "--lr-schedule", "cosine",
      "--target-kl", "0.01",
