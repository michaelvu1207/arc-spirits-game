  "soloMaxStatusLevel": 2,
  "maxRounds": 120,
  "gamesPerGen": 512,
  "matchupGames": 32,
  "evalGames": 48,
  "evalOpponents": ["heur-medium", "heur-hard", "heur-pvphunter"],
  "lanes": { "main": 1, "mainExploiter": 0, "leagueExploiter": 0 },
