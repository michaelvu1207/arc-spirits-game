	"shapingPreset": "ascend3",
	"potentialShapingMode": "policy-invariant",
	"strategicDecisionScope": "engine-cycle",
	"gamma": 0.999,
	"shuffleGuardians": true,
	"selfPlayFraction": 0,
	"heuristicOpponentFraction": 0,
	"opponentTemperature": 0.65,
