	"promoteMarginElo": 25,
	"selection": "hybrid",
	"sample": true,
	"temperature": 0.55,
	"train": {
		"epochs": 4,
		"batchSize": 256,
		"hidden": [512, 512],
		"valueHidden": [256],
		"ppoRowsPerEpoch": 120000,
		"ppoContinuationFraction": 0,
		"extraArgs": [
			"--lr", "0.00015",
			"--clip-eps", "0.15",
