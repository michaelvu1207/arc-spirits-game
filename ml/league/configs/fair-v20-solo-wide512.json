		"enabled": false,
		"rounds": [12, 16, 20],
		"sourceProbability": 1,
		"capFailureWeight": 1,
		"successWeight": 1
	},
	"maxRounds": 30,
	"gamesPerGen": 1024,
	"matchupGames": 64,
	"evalGames": 256,
	"evalOpponents": [],
