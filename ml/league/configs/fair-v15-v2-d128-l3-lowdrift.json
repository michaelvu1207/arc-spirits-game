	"v2": {
		"dModel": 128,
		"layers": 3,
		"heads": 4,
		"device": "cuda",
		"windowMs": 2,
		"maxBatch": 512,
		"distillEpochs": 4,
		"distillEveryGen": false
	},
	"seedCheckpointAnchors": true,
