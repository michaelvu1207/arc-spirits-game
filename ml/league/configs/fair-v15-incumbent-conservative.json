	"mode": "ppo",
	"seats": 4,
	"maxRounds": 120,
	"gamesPerGen": 512,
	"matchupGames": 32,
	"evalGames": 24,
	"evalOpponents": ["heur-medium", "heur-hard", "heur-pvphunter"],
	"lanes": { "main": 1, "mainExploiter": 0, "leagueExploiter": 0 },
	"seedCheckpointAnchors": true,
	"baselineElos": {
		"frozen-v13-1-gen48-champion": 439,
		"frozen-ladder8c2-gen60-champion": 136
	},
	"extraFrozen": [
		{
			"id": "frozen-v13-2-gen44-champion",
			"weightsPath": "ml/champions/v13-2/main-0-gen44.json",
			"elo": 453
		},
		{
			"id": "frozen-v14b-gen120-exploiter",
			"weightsPath": "ml/exploiters/v14b-gen120.json",
			"elo": 394
		}
	],
	"denseVpReward": true,
	"shapingPreset": "ascend3",
	"selfPlayFraction": 0.1,
	"opponentTemperature": 0.65,
	"pfsp": { "p": 2, "variant": "squared" },
	"promoteEvery": 0,
	"promoteMarginElo": 25,
