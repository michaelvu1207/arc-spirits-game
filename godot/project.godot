; Arc Spirits — Godot 4 client.
; Authored entirely as text (no editor GUI): scenes are .tscn, scripts are .gd,
; and all verification runs through the godot CLI (--headless import, scripted
; screenshot runs, headless exports). See godot/README.md for the agent workflow.

config_version=5

[application]

config/name="Arc Spirits"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.5")

[display]

; One logical canvas everywhere: 1280x720 design space, canvas_items stretch so
; phones/desktops/Steam Deck all scale the same layout (the "consistent UI +
; transferable performance" requirement).
window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

; Mobile renderer on every platform: identical feature set + performance
; envelope on iOS/Android/desktop, which keeps Steam and phone builds honest.
renderer/rendering_method="mobile"
renderer/rendering_method.mobile="mobile"
