# Supabase Configuration
# Copy this file to .env and fill in your values

PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-only; required for admin verification actions)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Host Secret Key (for editing game notes - only you should know this)
HOST_SECRET_KEY=your-secret-key-here

# Admin Secret Key (used for admin login; falls back to HOST_SECRET_KEY if unset)
ADMIN_SECRET_KEY=your-admin-secret-key-here

# Play API base origin. Leave EMPTY for the web build (same-origin + cookie auth).
# Set to the deployed backend origin (e.g. https://your-app.vercel.app) ONLY for
# the Capacitor native app build, which is cross-origin and cannot use the cookie.
PUBLIC_API_BASE_URL=

# Room WebSocket server origin (server/ long-lived room server). Leave EMPTY to run on the
# pure HTTP transport (Supabase broadcast + poll). When set, the play client opens a WS for
# optimistic command acks + server-pushed deltas, with the HTTP path as the safety-net
# fallback. Per-session override at runtime: `?ws=wss://host` / `?ws=0` (disable) query param,
# or localStorage['arc-play-ws-url']. e.g. wss://rooms.your-app.com
PUBLIC_WS_SERVER_URL=
